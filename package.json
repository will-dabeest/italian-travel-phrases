{
  "name": "italian-travel-phrase-trainer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:react": "vite --config vite.react.config.ts --open /react.html",
    "build": "vite build",
    "build:react": "vite build --config vite.react.config.ts",
    "preview": "vite preview",
    "preview:react": "vite preview --config vite.react.config.ts",
    "check": "tsc --noEmit",
    "test:parity:ui": "playwright test -c playwright.parity.config.ts",
    "test:parity:step2": "playwright test -c playwright.parity.config.ts --grep @step2",
    "test:parity:step3": "playwright test -c playwright.parity.config.ts --grep @step3",
    "test:parity:step4": "playwright test -c playwright.parity.config.ts --grep @step4",
    "test:parity:step5": "playwright test -c playwright.parity.config.ts --grep @step5",
    "test:parity:step6": "playwright test -c playwright.parity.config.ts --grep @step6",
    "ci:parity:gates": "npm run check && npm run build && npm run build:react",
    "ci:parity:checklist": "node scripts/ci/validate-react-parity-checklist.mjs",
    "ci:parity:ui": "npm run test:parity:ui -- --reporter=line",
    "ci:parity:all-steps": "npm run test:parity:ui -- --reporter=line",
    "ci:parity:step2": "npm run test:parity:step2 -- --reporter=line",
    "ci:parity:step3": "npm run test:parity:step3 -- --reporter=line",
    "ci:parity:step4": "npm run test:parity:step4 -- --reporter=line",
    "ci:parity:step5": "npm run test:parity:step5 -- --reporter=line",
    "ci:parity:step6": "npm run test:parity:step6 -- --reporter=line",
    "docker:build": "docker build -t italian-travel-phrase-trainer .",
    "docker:run": "docker run --rm -p 8080:80 italian-travel-phrase-trainer",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
